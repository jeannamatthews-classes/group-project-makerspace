FLASK_ENV=development
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/makerspace_db
SQLALCHEMY_TRACK_MODIFICATIONS=false

RFID_DEVICE_PATH=/dev/input/event3
RFID_API_URL=http://127.0.0.1:5000/api/access-events
RFID_DEVICE_ID=makerspace-reader-1
RFID_QUEUE_FILE=services/rfid_queue.json
RFID_RETRY_SECONDS=10
RFID_GRAB_DEVICE=true
RFID_REQUEST_TIMEOUT=5
